{
  "name": "@jimicze-pw/ordertest-core",
  "version": "0.1.0",
  "description": "Playwright Test plugin for deterministic, user-defined test execution ordering across files and test methods",
  "license": "MIT",
  "author": "jimicze",
  "repository": { "type": "git", "url": "git+https://github.com/jimicze/pw-plugin-ordertest.git" },
  "homepage": "https://github.com/jimicze/pw-plugin-ordertest#readme",
  "bugs": { "url": "https://github.com/jimicze/pw-plugin-ordertest/issues" },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schema"
  ],
  "publishConfig": { "access": "public" },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "playwright",
    "test",
    "ordering",
    "serial",
    "parallel",
    "e2e",
    "testing",
    "test-runner",
    "playwright-plugin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/ tests/",
    "lint:fix": "biome lint --write src/ tests/",
    "check": "biome check src/ tests/",
    "check:fix": "biome check --write src/ tests/",
    "format": "biome format --write src/ tests/",
    "format:check": "biome format src/ tests/",
    "test": "npx playwright test",
    "test:unit": "npx playwright test tests/unit/",
    "test:integration": "npx playwright test tests/integration/",
    "test:smoke": "npx playwright test tests/smoke/",
    "clean": "rm -rf dist .ordertest",
    "verify": "pnpm typecheck && pnpm check && pnpm test",
    "ci:check": "pnpm clean && pnpm build && pnpm check && pnpm test && pnpm test:smoke"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "dependencies": {
    "pino": "^9.0.0",
    "pino-roll": "^4.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  }
}
